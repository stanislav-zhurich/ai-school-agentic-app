# Copy this file to .env and fill in your values.

# Required: Azure OpenAI API key
OPENAI_API_KEY=your-azure-api-key-here

# Optional: Azure OpenAI endpoint (default: https://ai-proxy.lab.epam.com)
# AZURE_OPENAI_ENDPOINT=https://ai-proxy.lab.epam.com

# Optional: Azure OpenAI API version (default: 2024-10-21)
# AZURE_OPENAI_API_VERSION=2024-10-21

# Optional: Azure deployment name / model (default: gpt-4o)
# LLM_MODEL=gpt-4o

# Required: NewsData.io API key (free plan: 200 credits/day, sign up at https://newsdata.io/register)
NEWSDATA_API_KEY=your_newsdata_api_key_here
